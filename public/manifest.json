{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.2",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "description": "__MSG_appDescription__",
  "default_locale": "en",
  "action": {
    "default_popup": "index.html",
    "default_title": "ChanryTabStash"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}