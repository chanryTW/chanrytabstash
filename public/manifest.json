{
  "manifest_version": 3,
  "name": "ChanryTabStash",
  "version": "1.0.0",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "description": "A web tab manager to efficiently stash and restore tab groups with AI-powered categorization.",
  "action": {
    "default_popup": "index.html",
    "default_title": "ChanryTabStash"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}